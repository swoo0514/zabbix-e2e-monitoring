# =============================================================================
# 환경변수 템플릿 — 이 파일을 복사해 .env 로 만들고 값을 채우세요.
#   cp .env.example .env
# 실제 .env 는 비밀값을 포함하므로 git에 커밋되지 않습니다(.gitignore).
# =============================================================================

# --- PostgreSQL 자격증명 (Zabbix DB) ---
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=change_me_strong_password   # ★ 반드시 강한 값으로 변경
POSTGRES_DB=zabbix

# --- Zabbix Web Frontend ---
PHP_TZ=Asia/Seoul
ZBX_SERVER_NAME=Zabbix E2E Monitoring

# --- nginx /secure Basic Auth (고도화) ---
# 파생 파일 nginx/auth/.htpasswd 는 scripts/gen-htpasswd.sh 로 생성(커밋 금지).
NGINX_SECURE_USER=monitor
NGINX_SECURE_PASS=change_me_secure   # ★ 강한 값으로 변경

# =============================================================================
# 캡스톤 아크 (부하/유실 → Kafka → HA) — 실험용 knob. 평소엔 전부 주석/미설정 상태로 두면
# docker-compose가 공식 기본값을 쓰므로 검증 스택이 그대로 돈다. 실험 시에만 주석 해제.
# 상세: private/docs/capstone-arc-*.md
# =============================================================================

# --- [ACT1] 캐시 유실 재현 실험 통제 (기본 16M/4 = 공식값). 실험 후 다시 주석처리로 즉시 복원 ---
# ZBX_HISTORYCACHESIZE=128K   # 공식 Range 128K-2G(min). 랩 오버플로 재현용 통제, 생산 사이징 아님
# ZBX_STARTDBSYNCERS=1        # 공식 Range 1-100(min). DB 배수 지연 → 유실 임계 선명화

# --- [ACT2] Kafka (KRaft) — 클러스터 ID를 최초 1회 고정:
#   docker run --rm apache/kafka:3.9.1 /opt/kafka/bin/kafka-storage.sh random-uuid
# KAFKA_CLUSTER_ID=

# --- [ACT3] 서버 HA 노드 식별자 (빈값 = standalone = 검증스택 그대로). 실험 시에만 채움 ---
# ZBX_HANODENAME1=node1
# ZBX_NODEADDRESS1=zabbix-server:10051   # ★ localhost 금지(공식 기본 localhost:10051) — 컨테이너선 서비스명
